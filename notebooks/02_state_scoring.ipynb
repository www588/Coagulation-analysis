"""
Feature Engineering Module
1. Initial Coagulation State Scoring
2. Dynamic State Sequence Construction
3. Clinical Reward Function Calculation
4. Temporal Features (Time Intervals)
5. Patient Severity Stratification
"""
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import os
from scipy import stats

EPS = 1e-8
plt.rcParams['font.sans-serif'] = ['DejaVu Sans']
plt.rcParams['axes.unicode_minus'] = False

# ===================== 1. Initial State Scoring =====================
def assign_initial_state_xy(row):
    """
    Calculate initial state based on laboratory indicators
    Yx: Bleeding Tendency   Yy: Thrombosis Tendency
    """
    # Bleeding score
    bleeding_score = 0
    if pd.notna(row["APTT"]):
        bleeding_score += 2 if row["APTT"] > 60 else (1 if row["APTT"] > 40 else 0)
    if pd.notna(row["PT"]):
        bleeding_score += 2 if row["PT"] > 20 else (1 if row["PT"] > 15 else 0)
    if pd.notna(row["TT"]) and row["TT"] > 21:
        bleeding_score += 1
    if pd.notna(row["PLT"]):
        bleeding_score += 2 if row["PLT"] < 50 else (1 if row["PLT"] < 100 else 0)
    if pd.notna(row["Fib"]) and row["Fib"] < 2.0:
        bleeding_score += 1

    # Thrombosis score
    thrombus_score = 0
    if pd.notna(row["TAT"]):
        thrombus_score += 2 if row["TAT"] > 20 else (1 if row["TAT"] > 10 else 0)
    if pd.notna(row["PIC"]):
        thrombus_score += 2 if row["PIC"] > 3 else (1 if row["PIC"] > 1.5 else 0)
    if pd.notna(row["PAIC"]) and row["PAIC"] > 17.1:
        thrombus_score += 1
    if pd.notna(row["TM"]) and row["TM"] > 5.0:
        thrombus_score += 1
    if pd.notna(row["DD"]):
        thrombus_score += 2 if row["DD"] > 2 else (1 if row["DD"] > 0.5 else 0)
    if pd.notna(row["Fib"]) and row["Fib"] > 4.0:
        thrombus_score += 1

    return float(bleeding_score), float(thrombus_score)

# ===================== 2. Dynamic State Construction =====================
def build_dynamic_states(df):
    """Construct sequential dynamic states for each patient"""
    value_cols = ['TAT','PIC','PAIC','TM','PT','APTT','TT','Fib','DD','PLT','Hb','HCT']
    df = df.sort_values(["cycle_id", "Time"]).copy()
    df["Y_x"] = np.nan
    df["Y_y"] = np.nan

    for pid, g in df.groupby("cycle_id"):
        prev_vals = None
        prev_state = None

        for idx, row in g.iterrows():
            current_vals = row[value_cols]
            is_treat = pd.notna(row.get("Treat")) and str(row["Treat"]).strip() not in ["", "nan"]

            # Initial state
            if prev_state is None:
                Y_x, Y_y = assign_initial_state_xy(row)
                prev_state = np.array([Y_x, Y_y])
            else:
                # Freeze state during treatment
                if is_treat:
                    Y_x, Y_y = prev_state
                else:
                    dx, dy = 0.0, 0.0
                    for col in value_cols:
                        curr_val = current_vals[col]
                        prev_val = prev_vals[col] if prev_vals is not None else None
                        if pd.isna(curr_val) or pd.isna(prev_val):
                            continue
                        
                        delta = curr_val - prev_val
                        rel_delta = delta / (prev_val + EPS)

                        # Bidirectional effect of Fib
                        if col == "Fib":
                            if curr_val < prev_val: dx += abs(rel_delta)
                            elif curr_val > prev_val: dy += abs(rel_delta)
                            continue
                        
                        # Bleeding indicators
                        if col in ['PT','APTT','TT']: dx += rel_delta
                        elif col in ['PLT','Hb','HCT']: dx -= rel_delta
                        # Thrombosis indicators
                        else: dy += rel_delta
                    
                    # Amplitude clipping
                    dx = np.clip(dx, -1.0, 1.0)
                    dy = np.clip(dy, -1.0, 1.0)
                    Y_x = np.clip(prev_state[0]+dx, 0, 6)
                    Y_y = np.clip(prev_state[1]+dy, 0, 7)
                    prev_state = np.array([Y_x, Y_y])
            
            df.at[idx, "Y_x"] = round(Y_x, 2)
            df.at[idx, "Y_y"] = round(Y_y, 2)
            prev_vals = current_vals.copy()
    return df

# ===================== 3. Reward Function =====================
def compute_rewards(df):
    """Calculate clinical reward function"""
    df = df.sort_values(["cycle_id", "Time"]).copy()
    df["reward_state"] = 0.0
    df["reward_action"] = 0.0
    df["reward_step"] = -0.05
    df["reward_total"] = 0.0

    # Drug reward mapping
    action_reward = {
        'Low Molecular Weight Heparin':1.0, 'Heparin':1.0,
        'Factor Xa Inhibitor':1.0, 'Direct Thrombin Inhibitor':1.0,
        'Vitamin K Antagonist':1.0, 'Antiplatelet':1.0,
        'Defibrinogenolytic Agent':1.0, 'Hemostatic':1.0,
        'Blood Product':0.7, 'Other':0.0
    }

    for pid, g in df.groupby("cycle_id"):
        Yx, Yy = g["Y_x"], g["Y_y"]
        Yx_prev = Yx.shift(1).fillna(Yx)
        Yy_prev = Yy.shift(1).fillna(Yy)
        
        # State reward
        delta_x, delta_y = Yx_prev-Yx, Yy_prev-Yy
        reward_state = (delta_x+delta_y)*2.0
        reward_state = reward_state.clip(-2.0, 2.0)
        # Safe zone reward
        is_safe = (Yx<=1.0) & (Yy<=1.0)
        reward_state += is_safe*1.0
        
        # Action reward
        reward_act = g["drug_class"].map(action_reward).fillna(0.0)
        reward_total = reward_state + reward_act -0.05
        
        # Write back
        df.loc[g.index, "reward_state"] = reward_state.round(2)
        df.loc[g.index, "reward_action"] = reward_act.round(2)
        df.loc[g.index, "reward_total"] = reward_total.round(2)
    return df

# ===================== 4. Temporal Features =====================
def build_timing_features(df):
    """Construct time interval features"""
    df['Time'] = pd.to_datetime(df['Time'], errors='coerce')
    df['is_treat'] = df['Treat'].notna() & (df['Treat'].astype(str).str.strip() != '')
    df = df.sort_values(['cycle_id', 'Time']).reset_index(drop=True)

    def process_patient(g):
        g = g.copy()
        # Time differences
        g['hours_since_last'] = g['Time'].diff().dt.total_seconds()/3600
        g['hours_to_next'] = -g['Time'].diff(-1).dt.total_seconds()/3600
        g['last_is_treat'] = g['is_treat'].shift(1).fillna(False)
        
        # Hours since last treatment
        treat_mask = g['is_treat']
        if treat_mask.any():
            g['last_treat_time'] = g['Time'].where(treat_mask).ffill()
            g['hours_since_last_treat'] = (g['Time']-g['last_treat_time']).dt.total_seconds()/3600
        else:
            g['hours_since_last_treat'] = -1
        return g

    df = df.groupby('cycle_id', group_keys=False).apply(process_patient)
    time_cols = ['hours_since_last','hours_to_next','hours_since_last_treat']
    df[time_cols] = df[time_cols].fillna(-1)
    return df

# ===================== 5. Patient Stratification =====================
def patient_stratification(df):
    """Severity stratification: mild / moderate / severe"""
    patient_severity = []
    for pid, g in df.groupby("cycle_id"):
        distance = np.sqrt(g['Y_x']**2 + g['Y_y']**2)
        score = 0.7*distance.mean() + 0.3*distance.max()
        patient_severity.append({"cycle_id":pid, "severity_score":score})
    
    severity_df = pd.DataFrame(patient_severity)
    q = severity_df['severity_score'].quantile([0,0.33,0.66,1.0]).values
    severity_df['severity_stratum'] = pd.cut(severity_df['severity_score'], 
                                           bins=q, labels=['mild','moderate','severe'], include_lowest=True)
    
    # One-hot encoding
    onehot = pd.get_dummies(severity_df['severity_stratum'], prefix='severity')
    severity_df = pd.concat([severity_df, onehot], axis=1)
    df = df.merge(severity_df[['cycle_id','severity_stratum']+list(onehot.columns)], on='cycle_id', how='left')
    return df

# ===================== Main Function =====================
if __name__ == "__main__":
    # Load processed data
    df = pd.read_csv("processed_data.csv")
    # State construction
    df = build_dynamic_states(df)
    # Reward calculation
    df = compute_rewards(df)
    # Temporal features
    df = build_timing_features(df)
    # Patient stratification
    df = patient_stratification(df)
    # Save output
    df.to_csv("feature_engineered_data.csv", index=False, encoding='utf-8-sig')
    print("Feature engineering completed!")