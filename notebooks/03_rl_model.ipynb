"""
Reinforcement Learning Model Module
1. Data Batch Construction
2. BiLSTM + Attention Model
3. Model Training with Early Stopping
4. Result Saving
"""
import torch
import torch.nn as nn
import torch.optim as optim
import numpy as np
import pandas as pd
from sklearn.model_selection import train_test_split
from torch.utils.data import TensorDataset, DataLoader

# ===================== Configuration =====================
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
TIME_STEPS = 8
SEED = 42
torch.manual_seed(SEED)
np.random.seed(SEED)

# ===================== 1. Data Batch Construction =====================
def create_rl_batch(df):
    """Construct training batches for reinforcement learning"""
    # State / action columns
    state_cols = [
        'TAT','PIC','PAIC','TM','PT','APTT','TT','Fib','DD','PLT','Hb','HCT','CRP',
        'Y_x','Y_y','hours_since_last','hours_to_next','hours_since_last_treat',
        'severity_mild','severity_moderate','severity_severe'
    ]
    action_cols = [
        'drug_Other','drug_Antiplatelet','drug_Hemostatic','drug_Blood Product',
        'drug_Heparin','drug_Low Molecular Weight Heparin',
        'drug_Factor Xa Inhibitor','drug_Direct Thrombin Inhibitor',
        'drug_Vitamin K Antagonist'
    ]
    
    # Filter valid columns
    valid_state = [c for c in state_cols if c in df.columns]
    valid_action = [c for c in action_cols if c in df.columns]
    
    ids = df['cycle_id'].unique()
    B, F, A_dim = len(ids), len(valid_state), len(valid_action)
    
    # Initialize tensors
    X = np.zeros((B, TIME_STEPS, F), dtype=np.float32)
    A = np.zeros((B, TIME_STEPS, A_dim), dtype=np.float32)
    mask = np.zeros((B, TIME_STEPS), dtype=np.float32)
    R = np.zeros((B, TIME_STEPS), dtype=np.float32)
    
    # Reward normalization
    reward_vals = df['reward_total'].dropna()
    r_mean = reward_vals.mean() if len(reward_vals) > 0 else 0
    r_std = reward_vals.std() if len(reward_vals) > 0 else 1
    
    # Fill data
    for i, pid in enumerate(ids):
        sub = df[df['cycle_id'] == pid].sort_values('Time')
        seq_len = min(len(sub), TIME_STEPS)
        if seq_len == 0:
            continue
        
        X[i, :seq_len] = sub[valid_state].fillna(0).values[:seq_len]
        A[i, :seq_len] = sub[valid_action].fillna(0).values[:seq_len]
        mask[i, :seq_len] = 1.0
        r_vals = sub['reward_total'].fillna(0).values[:seq_len]
        R[i, :seq_len] = (r_vals - r_mean) / (r_std + 1e-8)
    
    return torch.tensor(X), torch.tensor(A), torch.tensor(R), torch.tensor(mask)

# ===================== 2. Model Definition =====================
class BiLSTMAttentionRL(nn.Module):
    def __init__(self, input_dim, num_actions, hidden_dim=32, dropout=0.6):
        super().__init__()
        self.lstm = nn.LSTM(input_dim, hidden_dim, batch_first=True, bidirectional=True)
        self.attn = nn.Linear(hidden_dim * 2, 1)
        self.dropout = nn.Dropout(dropout)
        self.out = nn.Linear(hidden_dim * 2, num_actions)
    
    def forward(self, x):
        out, _ = self.lstm(x)
        attn_score = torch.softmax(self.attn(out), dim=1)
        out = out * attn_score
        out = self.dropout(out)
        return self.out(out), attn_score

# ===================== 3. Model Result Class =====================
class RLModelResult:
    def __init__(self, name, train_loss, test_loss, Q_pred, A_batch, R_batch, mask_batch):
        self.name = name
        self.train_loss_list = train_loss
        self.test_loss_list = test_loss
        self.Q_pred = Q_pred
        self.A_batch = A_batch
        self.R_batch = R_batch
        self.mask_batch = mask_batch

# ===================== 4. Training Function =====================
def train_model(X, A, R, mask, model_name="Model3"):
    """Model training with early stopping"""
    # Data split
    B = X.shape[0]
    train_idx, test_idx = train_test_split(np.arange(B), test_size=0.15, random_state=SEED)
    X_train, X_test = X[train_idx], X[test_idx]
    A_train, A_test = A[train_idx], A[test_idx]
    R_train, R_test = R[train_idx], R[test_idx]
    mask_train, mask_test = mask[train_idx], mask[test_idx]
    
    # Data loaders
    train_loader = DataLoader(TensorDataset(X_train, A_train, R_train, mask_train), batch_size=32, shuffle=True)
    test_loader = DataLoader(TensorDataset(X_test, A_test, R_test, mask_test), batch_size=32, shuffle=False)
    
    # Model initialization
    model = BiLSTMAttentionRL(X.shape[-1], A.shape[-1]).to(device)
    optimizer = optim.AdamW(model.parameters(), lr=8e-5, weight_decay=1e-4)
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, patience=2, factor=0.5)
    criterion = nn.MSELoss(reduction='none')
    gamma = 0.95
    epochs = 50
    
    # Early stopping
    best_loss = float('inf')
    counter = 0
    train_losses, test_losses = [], []
    
    for epoch in range(epochs):
        # Training
        model.train()
        tr_loss = 0
        for xb, ab, rb, mb in train_loader:
            xb, ab, rb, mb = xb.to(device), ab.to(device), rb.to(device), mb.to(device)
            optimizer.zero_grad()
            qp, _ = model(xb)
            qt = (qp * ab).sum(-1)
            qn = torch.zeros_like(qt)
            if TIME_STEPS > 1:
                qn[:, :-1] = qp[:, 1:].max(-1)[0].detach()
            loss = (criterion(qt, rb + gamma * qn) * mb).sum() / (mb.sum() + 1e-8)
            loss.backward()
            optimizer.step()
            tr_loss += loss.item() * xb.size(0)
        tr_loss /= len(train_loader.dataset)
        train_losses.append(tr_loss)
        
        # Testing
        model.eval()
        te_loss = 0
        with torch.no_grad():
            for xb, ab, rb, mb in test_loader:
                xb, ab, rb, mb = xb.to(device), ab.to(device), rb.to(device), mb.to(device)
                qp, _ = model(xb)
                qt = (qp * ab).sum(-1)
                qn = torch.zeros_like(qt)
                if TIME_STEPS > 1:
                    qn[:, :-1] = qp[:, 1:].max(-1)[0]
                loss = (criterion(qt, rb + gamma * qn) * mb).sum() / (mb.sum() + 1e-8)
                te_loss += loss.item() * xb.size(0)
        te_loss /= len(test_loader.dataset)
        test_losses.append(te_loss)
        scheduler.step(te_loss)
        
        # Early stopping logic
        if te_loss < best_loss:
            best_loss = te_loss
            counter = 0
            torch.save(model.state_dict(), f"best_{model_name}.pth")
        else:
            counter += 1
            if counter >= 5:
                print("Early stopping triggered")
                break
        
        print(f"Epoch {epoch+1:02d} | Train {tr_loss:.4f} | Test {te_loss:.4f}")
    
    # Inference on test set
    model.load_state_dict(torch.load(f"best_{model_name}.pth"))
    model.eval()
    with torch.no_grad():
        Q_pred, _ = model(X_test.to(device))
        Q_pred = Q_pred.cpu()
    
    # Save training results
    result = RLModelResult(
        name=model_name,
        train_loss=train_losses,
        test_loss=test_losses,
        Q_pred=Q_pred,
        A_batch=A_test,
        R_batch=R_test,
        mask_batch=mask_test
    )
    torch.save(result, f"{model_name}_result.pt")
    return result

# ===================== Main Function =====================
if __name__ == "__main__":
    # Load data
    df = pd.read_csv("feature_engineered_data.csv")
    # Construct batches
    X, A, R, mask = create_rl_batch(df)
    # Train model
    model3_result = train_model(X, A, R, mask, "Model3")
    print("Model training completed, results saved!")