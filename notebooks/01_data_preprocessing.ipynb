"""
Coagulation Data Preprocessing Module
1. Data Loading & Basic Cleaning
2. Pharmacokinetic Time Feature Calculation
3. Drug Intervention Classification & One-Hot Encoding
"""
import pandas as pd
import numpy as np
import warnings
warnings.filterwarnings('ignore')

# ===================== Basic Configuration =====================
# Change to your data path
DATA_PATH = "E:/Paper/2025/0901血栓与止血/ACRLAII/data4.xlsx"
SAVE_PATH = "processed_data.csv"

# ===================== 1. Data Loading =====================
def load_data(file_path):
    """Load Excel data"""
    df = pd.read_excel(file_path, engine='openpyxl')
    print(f"Data loaded, total samples: {len(df)}")
    print(f"Number of patients: {len(df['ID'].unique())}")
    print(f"Number of treatment cycles: {len(df['cycle_id'].unique())}")
    return df

# ===================== 2. Pharmacokinetic Features =====================
def compute_pharmacokinetic_features(df):
    """Calculate PK time features: first dose, last dose, time differences"""
    # Convert time format
    df["Time"] = pd.to_datetime(df["Time"])
    df = df.sort_values(["cycle_id", "Time"]).reset_index(drop=True)
    
    # Label dosing / lab events
    df["event"] = np.where(df["Treat"].astype(str).str.strip() != "", "dose", "lab")
    
    # First & last dose time
    first_dose = df[df["event"] == "dose"].groupby("cycle_id")["Time"].min()
    df["first_dose_time"] = df["cycle_id"].map(first_dose)
    df["dose_time"] = df["Time"].where(df["event"] == "dose")
    df["dose_time"] = df.groupby("cycle_id")["dose_time"].ffill()
    
    # Time differences (hours)
    df["t_global_hr"] = (df["Time"] - df["first_dose_time"]).dt.total_seconds() / 3600
    df["t_last_dose_hr"] = (df["Time"] - df["dose_time"]).dt.total_seconds() / 3600
    
    # Baseline marker (before treatment)
    df["baseline"] = np.where((df["event"] == "lab") & (df["Time"] < df["first_dose_time"]), 1, 0)
    
    # Set NaN for patients without treatment
    mask = df["first_dose_time"].isna()
    df.loc[mask, ["t_global_hr", "t_last_dose_hr", "baseline"]] = np.nan
    
    return df

# ===================== 3. Drug Intervention Classification =====================
def classify_interventions(df):
    """Drug classification: Anticoagulant, Antiplatelet, Hemostatic, Blood Product, etc."""
    # Clean treatment field
    df['Treat'] = df['Treat'].astype(str).str.strip()
    df['Treat'] = df['Treat'].replace({'': np.nan, 'nan': np.nan, 'NaN': np.nan})
    
    # Drug class mapping
    drug_map = {
        # Anticoagulants
        '达肝素钠': 'Low Molecular Weight Heparin',
        '低分子肝素': 'Low Molecular Weight Heparin',
        '依诺肝素钠注射液': 'Low Molecular Weight Heparin',
        '那屈肝素钙注射液': 'Low Molecular Weight Heparin',
        '肝素钠': 'Heparin',
        '利伐沙班片': 'Factor Xa Inhibitor',
        '阿哌沙班片': 'Factor Xa Inhibitor',
        '阿加曲班注射液': 'Direct Thrombin Inhibitor',
        '华法林钠片': 'Vitamin K Antagonist',
        
        # Antiplatelets
        '阿司匹林肠溶片': 'Antiplatelet',
        '氢氯吡格雷片': 'Antiplatelet',
        '硫酸氢氯吡格雷片': 'Antiplatelet',
        '替罗非班注射液': 'Antiplatelet',
        '替格瑞洛片': 'Antiplatelet',
        
        # Defibrinogenolytic Agents
        '巴曲酶': 'Defibrinogenolytic Agent',
        '蕲蛇酶': 'Defibrinogenolytic Agent',
        
        # Hemostatics
        '氨甲环酸': 'Hemostatic',
        '酚磺乙胺注射液': 'Hemostatic',
        '注射用白眉蛇毒血凝酶': 'Hemostatic',
        '人凝血酶原复合物针': 'Hemostatic',
        '维生素K1注射液': 'Hemostatic',
        
        # Blood Products
        '红细胞': 'Blood Product',
        '冰冻血浆': 'Blood Product',
        '冷沉淀': 'Blood Product',
        '血浆': 'Blood Product',
        '去白细胞单采血小板': 'Blood Product'
    }
    
    def classify_drug(treat_str):
        if pd.isna(treat_str):
            return np.nan
        matched = set()
        for name, cls in drug_map.items():
            if name in treat_str:
                matched.add(cls)
        if not matched:
            return 'Other'
        return ' + '.join(sorted(matched))
    
    df['drug_class'] = df['Treat'].apply(classify_drug)
    # Generate one-hot dummies
    drug_dummies = pd.get_dummies(df['drug_class'], prefix='drug', dummy_na=False)
    df = pd.concat([df, drug_dummies], axis=1)
    
    return df

# ===================== Main Function =====================
if __name__ == "__main__":
    # Load data
    df = load_data(DATA_PATH)
    
    # Compute features
    df = compute_pharmacokinetic_features(df)
    df = classify_interventions(df)
    
    # Save processed data
    df.to_csv(SAVE_PATH, index=False, encoding='utf-8-sig')
    print(f"Preprocessing completed, data saved to: {SAVE_PATH}")