"""
Statistical Analysis Module
1. Data Missing Rate Statistics
2. Department Intervention Distribution
3. Time Interval Statistics
4. Inter-group Difference Test
"""
import pandas as pd
import numpy as np
import os
from scipy.stats import kruskal

# ===================== Configuration =====================
SAVE_DIR = r"E:\"
os.makedirs(SAVE_DIR, exist_ok=True)

# ===================== 1. Missing Value Statistics =====================
def calculate_missing_rate(df):
    """Calculate missing rate for laboratory indicators"""
    lab_cols = ['TAT','PIC','PAIC','TM','PT','APTT','TT','Fib','DD','PLT','Hb','HCT','CRP']
    # Keep only non-treatment rows
    df_non_treat = df[df['Treat'].isna()].copy()
    total = len(df_non_treat)
    
    result = []
    for col in lab_cols:
        miss_n = df_non_treat[col].isna().sum()
        miss_pct = miss_n / total * 100
        # Patient-level statistics
        patient_any = df_non_treat.groupby('cycle_id')[col].apply(lambda x: x.notna().any()).sum()
        patient_all = df_non_treat.groupby('cycle_id')[col].apply(lambda x: x.notna().all()).sum()
        
        result.append({
            'Indicator': col,
            'Total Samples': total,
            'Missing Count': miss_n,
            'Missing Rate (%)': round(miss_pct, 2),
            'Patients with At Least One Valid Value': patient_any,
            'Patients with All Valid Values': patient_all
        })
    pd.DataFrame(result).to_excel(os.path.join(SAVE_DIR, "Missing_Rate_Statistics.xlsx"), index=False)
    return pd.DataFrame(result)

# ===================== 2. Time Interval Statistics =====================
def calculate_time_intervals(df):
    """Calculate time intervals between consecutive tests"""
    df['Time'] = pd.to_datetime(df['Time'])
    df = df.sort_values(['cycle_id','Time'])
    df['delta_hours'] = df.groupby('cycle_id')['Time'].diff().dt.total_seconds() / 3600
    
    valid = df['delta_hours'][df['delta_hours'] > 0]
    stats = valid.describe()
    res = pd.DataFrame({
        'Metric': ['Mean', 'Std', 'Min', '25%', 'Median', '75%', 'Max', 'Valid Samples'],
        'Time Interval (Hours)': [round(stats['mean'], 2), round(stats['std'], 2),
                                 int(stats['min']), int(stats['25%']), int(stats['50%']),
                                 int(stats['75%']), int(stats['max']), int(stats['count'])]
    })
    res.to_excel(os.path.join(SAVE_DIR, "Time_Interval_Stats.xlsx"), index=False)
    return res

# ===================== 3. Inter-group Difference Test =====================
def group_difference_test(df):
    """Perform Kruskal-Wallis test across clinical groups"""
    # Group cleaning
    def clean_group(name):
        if pd.isna(name):
            return 'Other'
        if 'DIC' in str(name):
            return 'DIC'
        elif 'Thrombosis' in str(name) and 'Bleeding' not in str(name):
            return 'Thrombosis'
        elif 'Bleeding' in str(name) and 'Thrombosis' not in str(name):
            return 'Bleeding'
        else:
            return 'No_Event'
    
    df['Group'] = df['Group'].apply(clean_group)
    groups = ['No_Event', 'Bleeding', 'Thrombosis', 'DIC']
    
    # Kruskal-Wallis H-test
    yx_data = [df[df['Group'] == g]['Y_x'].dropna() for g in groups]
    yy_data = [df[df['Group'] == g]['Y_y'].dropna() for g in groups]
    
    kw_yx = kruskal(*yx_data)
    kw_yy = kruskal(*yy_data)
    
    res = pd.DataFrame({
        'Indicator': ['Y_x (Bleeding Tendency)', 'Y_y (Coagulation Tendency)'],
        'Chi-Square': [round(kw_yx.statistic, 2), round(kw_yy.statistic, 2)],
        'p-value': [f"{kw_yx.pvalue:.2e}", f"{kw_yy.pvalue:.2e}"]
    })
    res.to_excel(os.path.join(SAVE_DIR, "Group_Difference_Test.xlsx"), index=False)
    return res

# ===================== Main Function =====================
if __name__ == "__main__":
    df = pd.read_csv("feature_engineered_data.csv")
    # Missing rate
    miss_df = calculate_missing_rate(df)
    print("Missing rate statistics completed")
    # Time interval
    time_df = calculate_time_intervals(df)
    print("Time interval statistics completed")
    # Group test
    test_df = group_difference_test(df)
    print("Inter-group difference test completed")
    print("All statistical tables saved successfully!")